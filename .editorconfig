# EditorConfig helps developers define and maintain consistent
# coding styles between different editors and IDEs
# https://editorconfig.org

root = true

[*]
indent_style = tab
tab_width = 2
end_of_line = lf
charset = utf-8
insert_final_newline = true
max_line_length = 100

[*.json]
indent_style = tab

[*.lua]
indent_style = tab
indent_size = 4

[*.sql]
indent_style = tab
indent_size = 4

[*.md]
indent_style = tab
indent_size = 2
