root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
insert_final_newline = true
max_line_length = 120

[*.lua]
indent_size = 4

[*.sql]
indent_size = 4

[*.tsx, *.ts, *.js]
indent_size = 2

[*.json]
indent_size = 4
insert_final_newline = false
max_line_length = 200
