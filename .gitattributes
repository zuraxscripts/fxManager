# Normalize line endings to LF across all platforms.
* text=auto eol=lf

# Source & config (explicit)
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.lua   text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env   text eol=lf

# Lockfile
bun.lock text eol=lf -diff

# Binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text eol=lf
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
