{
  "name": "fxmanager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run src/server/index.ts",
    "build:client": "bun build src/client/entry.tsx --outdir dist/public --minify",
    "build:server": "bun build src/server/index.ts --compile --outfile dist/fxmanager",
    "build": "bun run build:client && bun run build:server"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "drizzle-orm": "^0.31.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
